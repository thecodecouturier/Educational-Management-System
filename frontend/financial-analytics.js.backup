    // 📊 رسم بياني للإيرادات السنوية
    createYearlyRevenueChart(yearlyData) {
        const ctx = document.getElementById('yearly-revenue-chart');
        if (!ctx || !yearlyData) return;
        
        if (this.charts.yearlyRevenue) {
            this.charts.yearlyRevenue.destroy();
        }
        
        const labels = yearlyData.map(data => data.year.toString());
        const expected = yearlyData.map(data => data.expected || 0);
        const collected = yearlyData.map(data => data.collected || 0);
        
        this.charts.yearlyRevenue = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'الإيراد المتوقع',
                        data: expected,
                        backgroundColor: 'rgba(148, 163, 184, 0.7)',
                        borderColor: '#94A3B8',
                        borderWidth: 1
                    },
                    {
                        label: 'الإيراد المحصل',
                        data: collected,
                        backgroundColor: 'rgba(16, 185, 129, 0.7)',
                        borderColor: '#10B981',
                        borderWidth: 1
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top'
                    },
                    title: {
                        display: true,
                        text: 'الإيرادات السنوية'
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return value + ' ج.م';
                            }
                        }
                    }
                }
            }
        });
    }

    // 📊 رسم بياني لتوزيع المجموعات
    createGroupDistributionChart(groupBreakdown) {
        const ctx = document.getElementById('group-distribution-chart');
        if (!ctx || !groupBreakdown || groupBreakdown.length === 0) return;
        
        if (this.charts.groupDistribution) {
            this.charts.groupDistribution.destroy();
        }
        
        const labels = groupBreakdown.map(group => group.subjectName || group.groupId);
        const revenues = groupBreakdown.map(group => group.collectedRevenue || group.expectedRevenue || 0);
        const colors = [
            '#10B981', '#3B82F6', '#F59E0B', '#EF4444', '#8B5CF6',
            '#EC4899', '#14B8A6', '#F97316', '#84CC16', '#6366F1'
        ];
        
        this.charts.groupDistribution = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: revenues,
                    backgroundColor: colors.slice(0, labels.length),
                    borderWidth: 2,
                    borderColor: '#ffffff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'right'
                    },
                    title: {
                        display: true,
                        text: 'توزيع الإيرادات حسب المجموعات'
                    }
                }
            }
        });
    }

    // 📊 رسم بياني لنسبة التحصيل
    createCollectionRateChart(monthlyData) {
        const ctx = document.getElementById('collection-rate-chart');
        if (!ctx || !monthlyData) return;
        
        if (this.charts.collectionRate) {
            this.charts.collectionRate.destroy();
        }
        
        const labels = monthlyData.map(data => data.month || data.fullMonth);
        const rates = monthlyData.map(data => data.collectionRate || 0);
        
        this.charts.collectionRate = new Chart(ctx, {
            type: 'area',
            data: {
                labels: labels,
                datasets: [{
                    label: 'نسبة التحصيل %',
                    data: rates,
                    borderColor: '#6366F1',
                    backgroundColor: 'rgba(99, 102, 241, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    title: {
                        display: true,
                        text: 'نسبة التحصيل عبر الوقت'
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 100,
                        ticks: {
                            callback: function(value) {
                                return value + '%';
                            }
                        }
                    }
                }
            }
        });
    }
}

document.addEventListener('DOMContentLoaded', () => {
    financialAnalyticsManager = new FinancialAnalyticsManager();
});

// إغلاق المودالات عند النقر خارجها
window.addEventListener('click', (event) => {
    const budgetModal = document.getElementById('budget-plan-modal');
    const transactionModal = document.getElementById('transaction-modal');
    
    if (event.target === budgetModal) {
        closeBudgetPlanModal();
    }
    
    if (event.target === transactionModal) {
        closeTransactionModal();
    }
});