        const labels = monthlyData.map(data => data.month || data.fullMonth);
        const expected = monthlyData.map(data => data.expected || 0);
        const collected = monthlyData.map(data => data.collected || 0);
        
        this.charts.monthlyRevenue = new Chart(ctx, {
