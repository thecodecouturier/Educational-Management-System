# ========================================
# إعدادات النشر العالمي للمؤسسات التعليمية
# ========================================

# 🏫 المنطقة الزمنية للمؤسسة (مهم جداً!)
# هذا يحدد متى تحدث الجدولة والعمليات التلقائية
INSTITUTION_TIMEZONE=Africa/Cairo

# 📊 قاعدة البيانات
DB_CONNECTION=mongodb://localhost:27017/school

# 🌍 أمثلة للمناطق الزمنية حسب الدولة:

# مصر
# INSTITUTION_TIMEZONE=Africa/Cairo

# الإمارات والسعودية
# INSTITUTION_TIMEZONE=Asia/Dubai
# INSTITUTION_TIMEZONE=Asia/Riyadh

# فرنسا وألمانيا
# INSTITUTION_TIMEZONE=Europe/Paris
# INSTITUTION_TIMEZONE=Europe/Berlin

# أمريكا
# INSTITUTION_TIMEZONE=America/New_York
# INSTITUTION_TIMEZONE=America/Los_Angeles

# اليابان والصين
# INSTITUTION_TIMEZONE=Asia/Tokyo
# INSTITUTION_TIMEZONE=Asia/Shanghai

# ========================================
# ملاحظات مهمة للنشر:
# ========================================

# 1. السيرفر السحابي يمكن أن يكون في أي مكان
# 2. INSTITUTION_TIMEZONE تحدد متى تحدث العمليات التلقائية
# 3. المستخدمون سيرون التوقيت المحلي في المتصفح
# 4. البيانات محفوظة بطريقة متسقة مع المنطقة الزمنية للمؤسسة

# مثال:
# سيرفر في أمريكا + مدرسة في مصر = INSTITUTION_TIMEZONE=Africa/Cairo
# سيرفر في مصر + مدرسة في الإمارات = INSTITUTION_TIMEZONE=Asia/Dubai
